<%- include('partials/header') %>

    <section class="form-section">
        <h2>Create New Post</h2>
        <form action="/posts" method="POST" class="blog-form">
            <div class="form-group">
                <label for="title">Title</label>
                <input type="text" id="title" name="title" required placeholder="Enter post title">
            </div>
            <div class="form-group">
                <label for="content">Content</label>
                <textarea id="content" name="content" required placeholder="Enter post content" rows="10"></textarea>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Create Post</button>
                <a href="/" class="btn btn-text">Cancel</a>
            </div>
        </form>
    </section>

    <%- include('partials/footer') %>